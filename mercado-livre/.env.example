# Copie este arquivo para ".env" e preencha com os dados do SEU app
# (portal de desenvolvedores do Mercado Livre). O .env fica fora do Git.

# App ID e Secret Key do app registrado.
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# Precisa ser IGUAL à Redirect URI cadastrada no app.
ML_REDIRECT_URI=http://localhost:8080/callback

# Domínio de login (Brasil). Só mude para outro país.
ML_AUTH_DOMAIN=https://auth.mercadolivre.com.br

# Site/marketplace: MLB = Brasil.
ML_SITE_ID=MLB
